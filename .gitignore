# build artifacts (the only checked-in binaries live under prebuilt/)
*.o
*.mod.c
*.mod.o
*.cmd
.tmp_versions/
Module.symvers
modules.order

# build outputs that ARE checked in under prebuilt/ — ignore everywhere else
/lib/*.a
/lib/*.so
/lib/*.so.*
/kernel/*.ko

# test binaries (only the curated ones in prebuilt/ are tracked)
/apps/vpu_test
/apps/vpu_stream
/apps/vpu_dec_fb3

# editor cruft
*~
*.swp
.DS_Store
